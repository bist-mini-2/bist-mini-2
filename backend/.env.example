# -----------------------------------------------------------------------------
# Bist Mini 2 FastAPI Backend - Environment Configuration Example
# 
# Copy this file to '.env' and adjust the settings as needed for your environment.
# -----------------------------------------------------------------------------

# Application Settings
APP_NAME="Bist Mini 2 API"
ENV="development"
HOST="0.0.0.0"
PORT=8000
DEBUG=true

# JWT Settings
# WARNING: Change this secret key in production!
JWT_SECRET_KEY="com.mycompany.backendapi.secret.key"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
# format: postgresql+asyncpg://<username>:<password>@<host>:<port>/<dbname>
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/postgres"

# OpenAI API Key
OPENAI_API_KEY=""
